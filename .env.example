# Copy this to .env and fill in your values
# cp .env.example .env

# --- LLM (optional) ---
# Without this, the API still works: retrieval runs locally,
# but answers will show raw context chunks instead of generated text.
OPENAI_API_KEY=

# Model to use for generation (any OpenAI-compatible model)
OPENAI_MODEL=gpt-4o-mini

# To use a local Ollama instance instead:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=llama3.2
# OPENAI_API_KEY=ollama  # required but ignored by Ollama

# --- Embeddings (local, no key needed) ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=knowledge_base

# --- Chunking ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Retrieval ---
TOP_K=5
SIMILARITY_THRESHOLD=0.3

# --- Upload limits ---
MAX_FILE_SIZE_MB=50
